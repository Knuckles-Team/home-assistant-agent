# ==============================================================================
# Home Assistant Agent Environment Configuration
# ==============================================================================

# --- Core API / Client Credentials for Home-Assistant ---
# 1. HOME_ASSISTANT_URL: The base URL of your Home Assistant instance.
HOME_ASSISTANT_URL=http://localhost:8123

# 2. HOME_ASSISTANT_TOKEN: Long-Lived Access Token generated from Home Assistant profile.
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# 3. AgentConfig transport policy (verification is mandatory).
# TLS_PROFILE=private-ca # Named transport profile
# TLS_PROFILE_REF=secret://transport/provider # Direct runtime profile reference
# TLS_PROFILES_REF=secret://transport/catalog # Named runtime profile catalog

# --- Core Agent Settings ---
# 4. DEFAULT_AGENT_NAME: The default name/display identifier for this agent.
DEFAULT_AGENT_NAME=HomeAssistantAgent

# 5. AGENT_DESCRIPTION: Brief description of the agent's responsibilities.
AGENT_DESCRIPTION=Expert assistant for interacting with and managing Home Assistant smart home devices.

# 6. AGENT_SYSTEM_PROMPT: Core system prompt directing the agent's behavior and traits.
AGENT_SYSTEM_PROMPT=You are a helpful, secure home automation AI assistant. You can control home assistant lights, switches, media players, calendars, and query historical data.

# --- Tool Toggle Switches (Set to True to enable, False to disable) ---
# 7. CONFIGTOOL: Enable config management tool.
CONFIGTOOL=True

# 8. STATESTOOL: Enable state inspection and modification tool.
STATESTOOL=True

# 9. SERVICESTOOL: Enable service call tool.
SERVICESTOOL=True

# 10. EVENTSTOOL: Enable event monitoring and subscription tool.
EVENTSTOOL=True

# 11. HISTORYTOOL: Enable historical state query tool.
HISTORYTOOL=True

# 12. LOGBOOKTOOL: Enable logbook and error log query tool.
LOGBOOKTOOL=True

# 13. CALENDARTOOL: Enable calendar schedule querying tool.
CALENDARTOOL=True

# 14. PANELSTOOL: Enable HA custom panels list tool.
PANELSTOOL=True

# 15. VOICETOOL: Enable voice entity exposition and settings tool.
VOICETOOL=True

# 16. ENTITIESTOOL: Enable entity registry lookup and display tool.
ENTITIESTOOL=True

# 17. SYSTEMTOOL: Enable templates, intents, and system health tools.
SYSTEMTOOL=True

# --- MCP Server & Transport Settings (FastMCP) ---
HOST=0.0.0.0
PORT=8000
TRANSPORT=stdio # Options: stdio, streamable-http, sse

# --- Telemetry & Observability (OTEL / Langfuse) ---
ENABLE_OTEL=True

# --- Enterprise Security & Access Governance (Eunomia) ---
EUNOMIA_TYPE=none # Options: none, embedded, remote
EUNOMIA_POLICY_FILE=mcp_policies.json
